function householdNRV(household){
  const totals = {};
  household.forEach(m => {
    const nrv = NRV[m.type] || NRV.man_19_50;
    Object.entries(nrv).forEach(([k,v]) => totals[k] = (totals[k]||0) + v);
  });
  return totals;
}

function subsistYield(crop,fertility,confidence){
  if(!crop.yield_low||!crop.yield_high)return 0;
  const mult=FERTILITY_MULT[fertility]||0.75;
  const mid=(crop.yield_low+crop.yield_high)/2;
  return(crop.yield_low+mid)/2*mult*(confidence/100);
}

function areaForServes(crop,servesPerDay,fertility,confidence){
  const sg=crop.serve_g||75;
  const annualKg=servesPerDay*sg*365/1000;
  const yieldKgHa=subsistYield(crop,fertility,confidence)*1000;
  if(yieldKgHa<=0)return null;
  return annualKg/yieldKgHa;
}

function cropLabour(crop,mechSystem){return mechSystem?(crop.labour_mech||50):(crop.labour_hand||1000)}


const OBJ_W={high:4, medium:1.5, low:0.4, off:0};


function cropScore(crop, fertility, confidence, zone, objectives){
  const obj = objectives || {minimiseLabour:"on", maximiseYield:"off", minimiseSpace:"off"};
  let score = 0;
  const adjYield = subsistYield(crop, fertility, confidence);
  if(obj.minimiseLabour === "on"){
    const lh = crop.labour_hand || 1000;
    score += Math.max(0, 1 - lh / 2200) * 100;
  }
  if(obj.maximiseYield === "on"){
    score += Math.min(adjYield / 20, 1) * 100;
  }
  if(obj.minimiseSpace === "on"){
    const servesPerM2 = adjYield * 1e6 / (crop.serve_g || 75) / 10000;
    score += Math.min(servesPerM2 / 150, 1) * 100;
  }
  return score;
}

function calcTotals(household){
  let t={veg:0,fruit:0,starchy:0,protein:0,dairy:0,oils:0};
  household.forEach(m=>{const a=ADG[m.type];if(a){t.veg+=a.veg;t.fruit+=a.fruit;t.starchy+=a.starchy;t.protein+=a.protein;t.dairy+=a.dairy;t.oils+=(a.oils||0);}});
  return t;
}

function cropPriorityTier(crop){
  const userTex=fd.soilTexture, rain=fd.annualRainfall;
  const opt=crop.text_opt||[], tol=crop.text_tol||[];
  const inText = opt.includes(userTex) || opt.includes("wide") || userTex==="wide";
  const inOptRain = crop.ropmn!=null && crop.ropmx!=null && rain>=crop.ropmn && rain<=crop.ropmx;
  const inAbsRain = crop.rain_min!=null && crop.rain_max!=null && rain>=crop.rain_min && rain<=crop.rain_max;
  if(inText && inOptRain) return 4;
  if(inText && inAbsRain) return 3;
  if(inOptRain) return 2;
  if(inAbsRain) return 1;
  return 0;
}

function fgToKey(fg){
  if(!fg) return null;
  const f = fg.toLowerCase();
  // Oils & Fats must be checked before protein — "seed" appears in oil seeds
  if(f.includes('oil') || (f.includes('fat') && !f.includes('protein'))) return 'oils';
  // Protein MUST come before veg — "Lean Meats, Eggs, Nuts, Seeds & Legumes" contains
  // "legume" but should map to protein, not veg.
  if(f.includes('meat') || f.includes('egg') || f.includes('nut') || f.includes('seed')) return 'protein';
  if(f.includes('dairy')) return 'dairy';
  if(f.includes('vegetable') || f.includes('legume')) return 'veg';
  if(f.includes('fruit')) return 'fruit';
  if(f.includes('grain') || f.includes('cereal')) return 'starchy';
  return null;
}

function getCropSeason(crop){
  if(crop.perennial) return null;
  const COOL = new Set(["may","jun","jul","aug","sep","oct"]); // Oct = cool
  const WARM = new Set(["nov","dec","jan","feb","mar","apr"]); // Apr = warm
  let cs = 0, ws = 0;
  Object.entries(crop.months||{}).forEach(([m,v]) => {
    const w = v==="P" ? 2 : v==="S" ? 1 : 0;
    if(COOL.has(m)) cs += w;
    if(WARM.has(m)) ws += w;
  });
  // Strictly one or the other — whichever has more harvest weight wins
  return ws > cs ? "warm" : "cool"; // default to cool if equal or no data
}

function lsServesPerDay(out, count){
  if(!count || count <= 0) return 0;
  // qty_per_animal_yr is in out.unit (g, mL, eggs)
  // serve_g converts to serves
  const totalGPerYr = out.unit === "eggs"
    ? count * out.qty_per_animal_yr * (out.serve_g || 55)  // eggs → grams
    : count * out.qty_per_animal_yr;                         // already in g or mL
  return (totalGPerYr / (out.serve_g || 100)) / 365;
}

const HERB_EXCLUSIONS = new Set([
  "Basil","Chives","Coriander (Fresh)","Dill","Mint","Parsley","Parsley (Curly)","Rosemary"
]);

const STARCHY_OVERRIDES = new Set([
  "Potato","Sweet Potato","Sweet Potato (Orange)","Sweet Potato (Purple)","Sweet Potato (White)",
  "Cassava","Taro","Yam","Arrowroot","Chestnut","Breadfruit","Artichoke (Jerusalem)",
]);

function effectiveFoodGroup(crop){
  if(STARCHY_OVERRIDES.has(crop.name)) return "Starches";
  if(crop.food_group==="Starches") return "Starches";
  if(crop.food_group==="Grain (Cereal) Foods") return "Starches";
  return crop.food_group;
}

function isSuitable(crop){
  const userZone = state.climateZone;
  const userTex  = state.soilTexture;
  // Both fields required — crops with no CLIZ or no TEXTR data are excluded
  const cropZones = crop.cliz || [];
  if(!cropZones.length) return false;
  if(!cropZones.includes(userZone)) return false;
  const cropTex = crop.text_tol || [];
  if(!cropTex.length) return false;
  if(userTex === "wide"){
    // user has variable soil — accept any crop with texture data
  } else {
    if(!cropTex.includes(userTex) && !cropTex.includes("wide")) return false;
  }
  return true;
}

function cropLayer(crop){
  const h = (crop && crop.h_max) || 0;
  if(h >= 25) return "canopy";    // ≥25m — overstory nut/tropical trees
  if(h >= 4)  return "trees";     // 4–24m — typical orchard fruit trees
  return "plants";                 // <4m — shrubs, vines, annuals
}

function generateAnnualPlan(cropCandidates, residualTargets, availHa, params){
  const s = params; // alias for minimal diff
  const annualBudget = s.hoursPerWeek * 52;
  const labourCap = annualBudget * 1.15;
  const isMech = s.labourSystem === "mech";
  const targets = residualTargets;
  // objectives handled via objMode

  // Build candidate pool with tier + objective score
  const candidates = cropCandidates
    .filter(c => !HERB_EXCLUSIONS.has(c.name))
    .map(c => ({
      crop: c,
      tier: cropPriorityTier(c),
      score: cropScore(c, s.fertility, s.confidence, s.climateZone, s.objectives),
      adjYield: subsistYield(c, s.fertility, s.confidence),
    }))
    .filter(x => x.tier > 0)
    .sort((a, b) => b.tier - a.tier || b.score - a.score);

  let usedCoolHa=0, usedWarmHa=0, usedLabour=0;
  const usedAnnualHa = () => usedCoolHa + usedWarmHa;
  const achieved={veg:0, fruit:0, starchy:0, protein:0, dairy:0, oils:0};
  const monthCoverage={}; MONTHS.forEach(m => monthCoverage[m]={veg:0,fruit:0,starchy:0,protein:0,dairy:0,oils:0});
  const selected=[];
  const lsSelected = [];
  

  function cropEfficiency(crop){
    const adjY = subsistYield(crop, s.fertility, s.confidence);
    const srvPerHa = adjY * 1e6 / (crop.serve_g || 75);
    const lph = cropLabour(crop, isMech);
    return lph > 0 ? srvPerHa / lph : srvPerHa * 99;
  }

  function addAllocation(crop, allocHa, key){
    const lph = cropLabour(crop, isMech);
    const actualLabour = lph * allocHa;
    const adjY = subsistYield(crop, s.fertility, s.confidence);
    // Annual averages: total serves per year ÷ 365 days
    const annualKg = allocHa * adjY * 1000;
    const totalServesYr = annualKg * 1000 / (crop.serve_g || 75);
    const actualServes = totalServesYr / 365;  // annual avg serves/day
    achieved[key] += actualServes;
    usedLabour += actualLabour;
    if(crop.perennial){
      usedPerennialHa += allocHa;
      const layer = cropLayer(crop);
      if(layer === "canopy") usedCanopyHa += allocHa;
      else if(layer === "trees") usedTreesHa += allocHa;
      else usedPerennialPlantsHa += allocHa;
    } else {
      const season = getCropSeason(crop);
      if(season === "warm") usedWarmHa += allocHa;
      else usedCoolHa += allocHa; // cool (default)
    }

    // Monthly: concentrate the year's harvest into the crop's actual harvest window
    // P (primary) month = weight 1, S (shoulder) = weight 0.5
    let harvestWeight = 0;
    MONTHS.forEach(m => {
      if(crop.months[m] === "P") harvestWeight += 1;
      else if(crop.months[m] === "S") harvestWeight += 0.5;
    });
    if(harvestWeight > 0){
      // Serves/day during one full primary month if all year's yield came out there
      const perMonthBase = totalServesYr / harvestWeight / 30;
      MONTHS.forEach(m => {
        const v = crop.months[m];
        const w = v === "P" ? 1 : v === "S" ? 0.5 : 0;
        if(w > 0) monthCoverage[m][key] += perMonthBase * w;
      });
    }
    // Byproduct: also credit secondary organ serves to their food group
    if(crop.byproducts && crop.byproducts.length){
      crop.byproducts.forEach(bp => {
        const bpYieldTha = adjY * (bp.yield_fraction || 0);
        const bpServesYr = allocHa * bpYieldTha * 1e6 / 75;
        const bpKey = fgToKey(bp.food_group);
        if(bpKey && achieved[bpKey] !== undefined){
          achieved[bpKey] += bpServesYr / 365;
          // Also spread into monthly coverage
          const bpMonths = bp.months || crop.months;
          let bpW = 0;
          MONTHS.forEach(m => { if(bpMonths[m]==='P') bpW+=1; else if(bpMonths[m]==='S') bpW+=0.5; });
          if(bpW > 0){
            const bpBase = bpServesYr / bpW / 30;
            MONTHS.forEach(m => {
              const v = bpMonths[m];
              const w = v==='P'?1:v==='S'?0.5:0;
              if(w > 0 && monthCoverage[m][bpKey] !== undefined) monthCoverage[m][bpKey] += bpBase * w;
            });
          }
        }
      });
    }
    const existing = selected.find(e => e.crop.name === crop.name);
    if(existing){
      existing.allocHa += allocHa;
      existing.serves += actualServes;
      existing.labour += actualLabour;
    } else {
      selected.push({crop, allocHa, serves: actualServes, labour: actualLabour, tier: cropPriorityTier(crop)});
    }
  }

  // ── PHASE 1: fill each food group to 100% sufficiency ────────────────────
  // Determine planning mode (single-select objective)
  const objMode = Object.keys(s.objectives||{}).find(k => s.objectives[k] === "on") || "balanced";

  // Pre-compute mode-specific score for every candidate
  // This is the PRIMARY sort key within a tier (replaces/extends cropScore)
  candidates.forEach(cand => {
    const adjY = cand.adjYield; // already computed
    const sg = cand.crop.serve_g || 75;
    if(objMode === "minimiseLabour"){
      const lh = cand.crop.labour_hand || 1;
      cand.modeScore = adjY * 1e6 / sg / lh;        // serves per labour-hr
    } else if(objMode === "minimiseSpace"){
      cand.modeScore = adjY * 1e6 / sg / 10000;     // serves per m2
    } else if(objMode === "maximiseYield"){
      cand.modeScore = adjY;                          // raw yield t/ha
    } else {
      cand.modeScore = cand.score;                    // balanced: cropScore 0-300
    }
  });

  // Protein/dairy groups: livestock competes with crops scored on serves/labour-hr
  const allPhase1Groups = [...FG_GROUPS];
  // no dairy from livestock candidates in succession planner

  allPhase1Groups.forEach(fg => {
    const isDairy = fg === '__dairy__';
    const key = isDairy ? 'dairy' : FG_KEY[fg];
    const targetServes = isDairy ? (targets.dairy||0) : (targets[key]||0);
    if(targetServes <= 0) return;
    const isFresh = (key === "veg" || key === "fruit");
    // Fresh crops always use tight cap for seasonal variety.
    // Non-fresh: minimiseLabour/Space use a larger cap so one efficient crop
    // can dominate the allocation, reducing total crop count.
    const perCropCap = isFresh ? 0.20 * targetServes
      : (objMode === "minimiseLabour" || objMode === "minimiseSpace")
        ? 0.75 * targetServes   // one dominant crop + one supplement
        : 0.50 * targetServes;  // balanced / maximiseYield
    const fgCandidates = candidates.filter(x => effectiveFoodGroup(x.crop) === fg);
    // no livestock candidates in succession planner
    const usedNames = new Set(selected.filter(s => effectiveFoodGroup(s.crop) === (isDairy ? '__dairy__' : fg)).map(s => s.crop.name));

    // Iterate; stop when target met AND (for fresh) worst month is at least 60%
    let iter = 0;
    while(iter++ < 40){
      const sufficient = achieved[key] >= targetServes - 0.1;
      const overPlanted = achieved[key] >= targetServes * 1.3;  // hard cap at 130% annual
      let worstMonthCov = 1.0, peakMonthCov = 0;
      if(isFresh){
        MONTHS.forEach(m => {
          const cov = (monthCoverage[m][key] || 0) / targetServes;
          if(cov < worstMonthCov) worstMonthCov = cov;
          if(cov > peakMonthCov) peakMonthCov = cov;
        });
      }
      const seasonallyEven = !isFresh || worstMonthCov >= 0.5;
      const gluttingHard = isFresh && peakMonthCov > 2.0;  // peak > 200% = stop
      // minimiseSpace: stop exactly at sufficiency (don't gap-fill beyond 100%)
      if(sufficient && (seasonallyEven || objMode === "minimiseSpace")) break;
      if(overPlanted || gluttingHard) break;  // hard caps

      // ── Best crop candidate ────────────────────────────────────────────────
      // 3-key comparator: tier (hard gate) → primary key → secondary key
      // Primary/secondary keys depend on planning mode:
      //   balanced:       gap-fill → cropScore
      //   minimiseLabour: modeScore (serves/labour-hr) → gap-fill
      //   minimiseSpace:  modeScore (serves/m2)        → gap-fill
      //   maximiseYield:  modeScore (yield t/ha)       → gap-fill
      let best = null;
      let bestTier = -1, bestPrimary = -Infinity, bestSecondary = -Infinity;

      for(const cand of fgCandidates){
        if(usedNames.has(cand.crop.name)) continue;
        let gapFillScore = 0, glutPenalty = 0;
        if(isFresh){
          MONTHS.forEach(m => {
            const v = cand.crop.months[m];
            const w = v === "P" ? 1 : v === "S" ? 0.5 : 0;
            if(w === 0) return;
            const cov = (monthCoverage[m][key] || 0) / targetServes;
            if(cov < 1.0) gapFillScore += (1.0 - cov) * w;
            else glutPenalty += (cov - 1.0) * w * 1.0;
          });
          if(sufficient && (gapFillScore - glutPenalty) <= 0.1) continue;
        }
        const netGap = gapFillScore - glutPenalty;

        // Assign primary and secondary keys by mode
        // For fresh crops: gap-fill is always primary (seasonal variety preserved)
        let primary, secondary;
        if(isFresh || objMode === "balanced"){
          primary   = netGap;
          secondary = cand.modeScore;
        } else {
          // Non-fresh + non-balanced: objective metric is primary, gap is tiebreaker
          primary   = cand.modeScore;
          secondary = netGap;
        }

        const tierWins  = cand.tier > bestTier;
        const tierTies  = cand.tier === bestTier;
        const primWins  = tierTies && primary > bestPrimary + 1e-6;
        const primTies  = tierTies && Math.abs(primary - bestPrimary) <= 1e-6;
        const secWins   = primTies && secondary > bestSecondary + 1e-6;

        if(tierWins || primWins || secWins){
          best = cand;
          bestTier = cand.tier; bestPrimary = primary; bestSecondary = secondary;
        }
      }

      const bestLs = null; // livestock pre-computed

      // ── Allocate best crop ────────────────────────────────────────────────────
      if(best){
        usedNames.add(best.crop.name);
        const remaining = targetServes - achieved[key];
        let wantServes = sufficient ? perCropCap * 0.25 : Math.min(remaining, perCropCap);
        if(wantServes <= 0.01) continue;
        const areaNeeded = areaForServes(best.crop, wantServes, s.fertility, s.confidence);
        if(!areaNeeded || areaNeeded <= 0) continue;
        const isAnnual2 = !best.crop.perennial;
        let available;
        if(isAnnual2){
          const season2 = getCropSeason(best.crop);
          available = season2==="warm" ? availHa - usedWarmHa : availHa - usedCoolHa;
        } else { continue; } // no perennial allocation in succession
        if(available <= 0.0005) continue;
        let allocHa = Math.min(areaNeeded, available);
        const lph = cropLabour(best.crop, isMech);
        const labourLeft = labourCap - usedLabour;
        if(lph * allocHa > labourLeft){ allocHa = lph > 0 ? labourLeft / lph : 0; if(allocHa <= 0.0005) continue; }
        addAllocation(best.crop, allocHa, key);
      } else { break; }
    }
  });

  // Phase 1.5 result — hoisted so plan return can always access it
  let p15NutsCovered = [];
  let p15GapNamesAll = [];

  // ── PHASE 1.5: Nutrient gap filling ──────────────────────────────────────
  // After food-group serves are met, allocate remaining land to close NRV gaps.
  // Only runs if the household is defined and there is remaining space.
  // Crops are scored by nutrient density per ha for the worst-gap nutrient.
  // Threshold: try to reach 85% of each daily NRV target.
  if(s.household && s.household.length > 0){
    const P15_THRESHOLD = 0.85;
    const P15_MAX_CROPS = 6;
    // Nutrients we don't try to fill via crops (either fine by default, or not trackable)
    const P15_SKIP = new Set(["fat","carbs","p","na","cu","mn"]);

    // Build running daily nutrient accumulator from current plan
    const nutAccum = {};
    selected.forEach(({crop, allocHa}) => {
      if(!crop.nut) return;
      const adjY = subsistYield(crop, s.fertility, s.confidence);
      const annualKgPerHa = adjY * 1000;
      Object.entries(crop.nut).forEach(([k, per100g]) => {
        nutAccum[k] = (nutAccum[k]||0) + allocHa * annualKgPerHa * 1000 * per100g / 100 / 365;
      });
    });
    // lsSelected NRV: pre-computed outside

    // Get household daily NRV targets
    const nrvDaily = householdNRV(s.household);

    // Find nutrients below threshold, worst first
    const p15Gaps = Object.entries(nrvDaily)
      .filter(([k, need]) => !P15_SKIP.has(k) && need > 0 && (nutAccum[k]||0) < need * P15_THRESHOLD)
      .sort((a,b) => (nutAccum[a[0]]||0)/a[1] - (nutAccum[b[0]]||0)/b[1]);
    // Record which gap nutrients were found (regardless of whether space allowed action)
    p15GapNamesAll = p15Gaps.slice(0, 6).map(([k]) => NUTRIENT_LABELS[k]).filter(Boolean);

    if(p15Gaps.length > 0){
      // Pool: ALL suitable checked crops with nut data — including those already in
      // the Phase 1 plan. Phase 1.5 can top up an existing crop if it's the best
      // source for a gap nutrient; that's often better than forcing a suboptimal new crop.
      const p15Pool = candidates.filter(c =>
        c.crop.nut && !HERB_EXCLUSIONS.has(c.crop.name)
      );
      // Separate tracking for crops already used within Phase 1.5 (prevents the same
      // crop being picked for two different gap nutrients within the P15 budget).
      const p15AllocNames = new Set();
      const p15Handled = new Set();
      let p15Count = 0;
      for(const [gapKey, gapNeed] of p15Gaps){
        if(p15Count >= P15_MAX_CROPS) break;
        if(p15Handled.has(gapKey)) continue;
        if((nutAccum[gapKey]||0) >= gapNeed * P15_THRESHOLD) continue;

        // Score pool by annual nutrient yield per ha for this gap
        const scored = p15Pool
          .filter(c => !p15AllocNames.has(c.crop.name) && (c.crop.nut[gapKey]||0) > 0)
          .map(c => ({ cand:c, nutPerHaYr: c.adjYield * 10000 * (c.crop.nut[gapKey]||0) }))
          .filter(x => x.nutPerHaYr > 0)
          .sort((a,b) => b.nutPerHaYr - a.nutPerHaYr);

        if(!scored.length){ p15Handled.add(gapKey); continue; }

        const {cand: top, nutPerHaYr} = scored[0];
        const isAnn = !top.crop.perennial;
        const s15 = isAnn ? getCropSeason(top.crop) : null;
        const spaceLeft = isAnn
          ? (s15==="warm" ? availHa - usedWarmHa : availHa - usedCoolHa)
          : s.perennialHa - perennialFootprint();
        if(spaceLeft < 0.005){ p15Handled.add(gapKey); continue; }

        const lph15 = cropLabour(top.crop, isMech);
        const labLeft15 = labourCap - usedLabour;
        if(lph15 > 0 && labLeft15 < 0.5){ p15Handled.add(gapKey); continue; }

        // Area needed to fill gap to threshold
        const gapDaily = gapNeed * P15_THRESHOLD - (nutAccum[gapKey]||0);
        let ha15 = nutPerHaYr > 0 ? (gapDaily * 365) / nutPerHaYr : 0;
        ha15 = Math.min(ha15, spaceLeft * 0.35); // cap at 35% of remaining space
        if(lph15 > 0) ha15 = Math.min(ha15, labLeft15 / lph15);
        if(ha15 < 0.002){ p15Handled.add(gapKey); continue; }

        const fgKey15 = FG_KEY[effectiveFoodGroup(top.crop)] || 'veg';
        addAllocation(top.crop, ha15, fgKey15);
        p15AllocNames.add(top.crop.name);
        p15Count++;

        // Update nutAccum and mark any nutrients now covered
        const addedAnnKg = ha15 * top.adjYield * 1000;
        Object.entries(top.crop.nut).forEach(([k, per100g]) => {
          const dailyG = addedAnnKg * 1000 * per100g / 100 / 365;
          nutAccum[k] = (nutAccum[k]||0) + dailyG;
          if((nutAccum[k]||0) >= (nrvDaily[k]||0) * P15_THRESHOLD) p15Handled.add(k);
        });
        p15Handled.add(gapKey);
      }
      // Write results into hoisted variable for plan return
      p15NutsCovered = [...p15Handled]
        .filter(k => !["fat","carbs","p","na","cu","mn"].includes(k))
        .map(k => NUTRIENT_LABELS[k]).filter(Boolean);
    }
  }

  // (p15NutsCovered is set inside the Phase 1.5 block above)

  // ── PHASE 2: maximiseYield → fill ALL remaining land/labour ──────────────
  // Runs only for maximiseYield mode. Adds new crops AND tops up existing ones.
  if(objMode === "maximiseYield"){
    // Sort candidates by tier (suitability) then adjusted yield, highest first
    const yieldOrder = [...candidates].sort((a, b) =>
      b.tier - a.tier || b.adjYield - a.adjYield
    );
    // Livestock sorted by serves/day per step (most productive first)
    const lsYieldOrder = [...lsCandidates].sort((a, b) => b.servesPerStep - a.servesPerStep);

    let safety = 0;
    while(safety++ < 300){
      // Re-compute all remaining budgets each iteration
      const coolLeft2    = availHa    - usedCoolHa;
      const warmLeft2    = availHa    - usedWarmHa;
      const perennialLeft = 0;
      const labourLeft    = labourCap     - usedLabour;
      const pastureLeft   = 0;

      if(coolLeft2 < 0.001 && warmLeft2 < 0.001 && perennialLeft < 0.001 && labourLeft < 1 && pastureLeft < 0.001) break;

      let allocated = false;

      // ── Try crops first (highest yield crop that still has space + labour) ──
      for(const cand of yieldOrder){
        const isAnnual = !cand.crop.perennial;
        const season2 = isAnnual ? getCropSeason(cand.crop) : null;
        const spaceLeft = isAnnual
          ? (season2==="cool" ? coolLeft2 : season2==="warm" ? warmLeft2 : Math.max(coolLeft2,warmLeft2))
          : perennialLeft;
        if(spaceLeft < 0.001) continue;
        const lph = cropLabour(cand.crop, isMech);
        const maxByLabour = lph > 0 ? Math.min(spaceLeft, labourLeft / lph) : spaceLeft;
        // Allocate 25% of the remaining budget in each pass — fills budgets in ~4-5 passes
        const allocHa = Math.min(spaceLeft * 0.25, maxByLabour);
        if(allocHa < 0.0005) continue;
        const fg  = effectiveFoodGroup(cand.crop);
        const key = FG_KEY[fg];
        if(!key) continue;
        addAllocation(cand.crop, allocHa, key);
        allocated = true;
        break;  // one allocation per iteration so budgets are rechecked
      }

      // ── Then try livestock for remaining pasture / labour ──────────────────
      if(!allocated && false){
        for(const lc of lsYieldOrder){
          if(lc.spaceHaPerStep > pastureLeft + 0.0001) continue;
          if(lc.labourPerStep  > labourLeft  + 0.1)   continue;
          const maxByPasture = Math.floor((pastureLeft + 0.0001) / lc.spaceHaPerStep);
          const maxByLabour2 = lc.labourPerStep > 0
            ? Math.floor(labourLeft / lc.labourPerStep) : maxByPasture;
          const nSteps = Math.min(maxByPasture, maxByLabour2, 10);
          if(nSteps < 1) continue;
          addLivestockAllocation(lc, nSteps * lc.ls.step);
          allocated = true;
          break;
        }
      }

      if(!allocated) break;
    }
  }

  return {selected, lsSelected:[], achieved, targets, usedCoolHa, usedWarmHa, usedAnnualHa: usedCoolHa+usedWarmHa, usedLabour, annualBudget, monthCoverage, suitableCount: candidates.length, p15NutsCovered: p15NutsCovered||[], p15GapNamesAll: p15GapNamesAll||[]};
}

// ═══════════════════════════════════════════════════════════════════════════
// LINEAR PROGRAMME (LP) PLAN GENERATION — OPTION D
// ═══════════════════════════════════════════════════════════════════════════
// Formulates farm planning as a constrained optimisation problem and solves
// it with a Big-M simplex. Unlike the greedy generatePlan() above (which fills
// food-group serves first, then patches nutrient gaps), the LP considers all
// constraints and trade-offs jointly. Output is a true optimum (within the
// modelling assumptions): minimum land use that meets household NRVs.
//
// Decision variables:
//   x_i  ∈ [0,∞)  = hectares of crop i
//   y_j  ∈ [0,∞)  = head count of livestock species j (continuous in LP,
//                    rounded to species step after)
//   u_n  ∈ [0,∞)  = unmet fraction of NRV for nutrient n (slack — penalised)
//   v_g  ∈ [0,∞)  = unmet fraction of food-group g serves (slack — penalised)

// ── State ─────────────────────────────────────────────────────────────────────
let fd = null, cy = 1, HZ = 25, yc = [], tlChart = null;
const FG_COLORS = {veg:"#6B9E58",fruit:"#E8983A",starchy:"#C4A84A",protein:"#5878B4",oils:"#9E6B58",dairy:"#7AABB4"};
const FG_LABELS = {veg:"Vegetables",fruit:"Fruit",starchy:"Grains",protein:"Protein",oils:"Oils & Fats",dairy:"Dairy"};

// ── Perennial canopy / yield model ────────────────────────────────────────────
function fpHa(c){ const r=((c.w_max||4)/2)+0.25; return Math.PI*r*r/10000; }
function nT(c){ const fp=fpHa(c); return fp>0?Math.max(1,Math.floor(c.allocHa/fp)):1; }
function cHaAt(c,age){ return nT(c)*fpHa(c)*Math.min(1,Math.pow(Math.max(0,age/((c.ytp||6)*1.5)),0.5)); }
function totCHa(yr){ return fd.perennials.reduce((s,c)=>s+cHaAt(c,yr),0); }

function perenYldTha(c,age){
  const ffy=c.ffy||2,ytp=c.ytp||6,n=c.n||0.6,yh=c.yield_high||1;
  if(age<ffy)return 0; if(ytp<=ffy)return yh;
  return yh*Math.min(1,Math.pow(Math.max(0,(age-ffy)/(ytp-ffy)),n));
}
function perenSpd(c,age){ return c.allocHa*perenYldTha(c,age)*1e6/(c.adg_serve_g||150)/365; }

