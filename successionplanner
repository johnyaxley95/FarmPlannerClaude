function showErr(m){ document.getElementById("lerr").textContent=m; }

function loadPlan(){
  const code=document.getElementById("ic").value.trim();
  if(!code){showErr("Paste export code first."); return;}
  try{
    const o=JSON.parse(decodeURIComponent(escape(atob(code))));
    if(!o.annualCrops){ showErr("Use the v25+ Export for Succession Planner button."); return; }
    initFarm(o);
  }catch(e){ showErr("Cannot read code: "+e.message); }
}

