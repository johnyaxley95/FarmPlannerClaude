function renderTimeline(){
  const el=document.getElementById("tlc"); if(!el)return;
  if(tlChart){tlChart.destroy();tlChart=null;}
  const lbs=yc.map(y=>"Yr "+y.yr);
  const ds=Object.entries(FG_LABELS).map(([k,l])=>({
    label:l, data:yc.map(y=>Math.min(150,y.cov[k]||0)),
    borderColor:FG_COLORS[k], backgroundColor:"transparent",
    tension:0.35, pointRadius:0, borderWidth:1.8,
  }));
  ds.push({label:"Overall",data:yc.map(y=>y.avg),
    borderColor:"#2A5C20",backgroundColor:"rgba(42,92,32,0.06)",fill:true,
    tension:0.35,pointRadius:0,borderWidth:3});
  // Perennial-only line (dashed)
  ds.push({label:"Perennial only",
    data:yc.map(y=>Math.round(Object.values(y.perenOnlyCov).reduce((s,v)=>s+v,0)/Object.keys(y.perenOnlyCov).length)),
    borderColor:"#2A5C20",backgroundColor:"transparent",borderDash:[4,3],
    tension:0.35,pointRadius:0,borderWidth:1.5});

  const vl={id:"vl",afterDraw(ch){
    const idx=cy-1; const m=ch.getDatasetMeta(0); if(!m?.data[idx])return;
    const x=m.data[idx].x; const c2=ch.ctx;
    c2.save();c2.beginPath();c2.moveTo(x,ch.chartArea.top);c2.lineTo(x,ch.chartArea.bottom);
    c2.strokeStyle="rgba(42,92,32,.5)";c2.lineWidth=1.5;c2.setLineDash([4,3]);c2.stroke();c2.restore();
  }};

  tlChart=new Chart(el,{type:"line",plugins:[vl],data:{labels:lbs,datasets:ds},options:{
    responsive:true,maintainAspectRatio:false,
    interaction:{mode:"index",intersect:false},
    plugins:{
      legend:{display:false},
      tooltip:{backgroundColor:"#FDFAF4",borderColor:"#D4C9A8",borderWidth:1,
        titleColor:"#2C2C1E",bodyColor:"#6B6455",padding:8,
        callbacks:{label:i=>` ${i.dataset.label}: ${i.parsed.y}%`}},
      annotation:{annotations:{line100:{type:"line",yMin:100,yMax:100,
        borderColor:"rgba(42,92,32,.4)",borderWidth:1.5,borderDash:[6,4],
        label:{display:true,content:"100% target",position:"end",
          font:{size:10},color:"var(--gdk)",backgroundColor:"transparent"}}}}
    },
    scales:{
      x:{ticks:{color:"#888",font:{size:10},maxTicksLimit:13},grid:{color:"rgba(0,0,0,.04)"},border:{color:"rgba(0,0,0,.1)"}},
      y:{min:0,max:155,ticks:{color:"#888",font:{size:10},callback:v=>v+"%"},grid:{color:"rgba(0,0,0,.04)"},border:{color:"rgba(0,0,0,.1)"}},
    }
  }});
}

function renderGantt(){
  const el=document.getElementById("gantt"); if(!el)return;
  const W=Math.max(el.clientWidth||700,700);
  const ROW=22, PAD=6, LABEL=160, BAR=W-LABEL-40;
  const years=HZ;
  const xScale=i=>LABEL+(i/years)*BAR;
  const perens=[...fd.perennials].sort((a,b)=>(a.ytp||8)-(b.ytp||8));

  let svg=`<svg width="${W}" height="${perens.length*(ROW+PAD)+30}" xmlns="http://www.w3.org/2000/svg" style="font-family:system-ui,sans-serif">`;
  // Year axis
  svg+=`<line x1="${LABEL}" y1="20" x2="${LABEL+BAR}" y2="20" stroke="#C8B99A" stroke-width="1"/>`;
  for(let y=0;y<=years;y+=5){
    const x=xScale(y);
    svg+=`<line x1="${x}" y1="16" x2="${x}" y2="24" stroke="#C8B99A" stroke-width="1"/>`;
    if(y>0)svg+=`<text x="${x}" y="14" text-anchor="middle" font-size="9" fill="#7A6A54">Yr ${y}</text>`;
  }
  // Current year marker
  const cx=xScale(cy-1);
  svg+=`<line x1="${cx}" y1="0" x2="${cx}" y2="${perens.length*(ROW+PAD)+30}" stroke="rgba(42,92,32,.5)" stroke-width="1.5" stroke-dasharray="4,3"/>`;

  perens.forEach((p,i)=>{
    const y0=24+i*(ROW+PAD);
    const k=fgToKey(p.food_group)||'veg';
    const col=FG_COLORS[k]||"#888";
    const ffy=p.ffy||3, ytp=p.ytp||8;
    // Crop name
    svg+=`<text x="${LABEL-6}" y="${y0+ROW/2+4}" text-anchor="end" font-size="11" fill="#2C2C1E" font-weight="500">${p.name.length>18?p.name.slice(0,17)+"…":p.name}</text>`;
    // Full bar background
    svg+=`<rect x="${LABEL}" y="${y0}" width="${BAR}" height="${ROW}" rx="3" fill="#F0EBE0"/>`;
    // Establishment phase
    const x1=xScale(0), x2=xScale(Math.min(ffy,years));
    svg+=`<rect x="${x1}" y="${y0}" width="${x2-x1}" height="${ROW}" rx="3" fill="#C8B99A"/>`;
    // Ramp phase  
    if(ffy<years){
      const x3=xScale(Math.min(ytp,years));
      svg+=`<rect x="${x2}" y="${y0}" width="${x3-x2}" height="${ROW}" rx="0" fill="${col}" opacity=".5"/>`;
      // Peak phase
      if(ytp<years){
        const x4=xScale(years);
        svg+=`<rect x="${x3}" y="${y0}" width="${x4-x3}" height="${ROW}" rx="0" fill="${col}"/>`;
      }
    }
    // Label on bar
    const midX=(xScale(0)+xScale(Math.min(ffy,years)))/2;
    if(ffy>=3) svg+=`<text x="${midX}" y="${y0+ROW/2+4}" text-anchor="middle" font-size="9" fill="#7A6A54">est.</text>`;
    // Current year yield dot
    if(cy>=ffy){
      const dot_x=xScale(cy-1);
      const pct=sn_pct(p);
      if(pct>0){
        svg+=`<circle cx="${dot_x}" cy="${y0+ROW/2}" r="${Math.max(2,ROW/2*Math.min(pct/100,1))}" fill="${col}" stroke="#fff" stroke-width="1" opacity=".9"/>`;
        svg+=`<text x="${dot_x+6}" y="${y0+ROW/2+4}" font-size="9" fill="${col}" font-weight="700">${pct}%</text>`;
      }
    }
  });
  svg+="</svg>";
  el.innerHTML=svg;
}

function sn_pct(p){
  const snap=yc[cy-1];
  const pd=snap.perenDetail.find(x=>x.name===p.name);
  return pd?pd.pct:0;
}

</script>
