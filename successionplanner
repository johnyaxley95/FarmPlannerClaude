function initFarm(o){
  const perenNames = new Set((o.planSnapshot||[]).map(s=>s.name));
  fd = {
    household: o.household || [],
    hoursPerWeek: o.hoursPerWeek || 20,
    labourSystem: o.labourSystem || "hand",
    fertility: o.fertility || "medium",
    confidence: o.confidence || 75,
    soilTexture: o.soilTexture || "medium",
    annualRainfall: o.annualRainfall || 750,
    climateZone: o.climateZone || "Cs",
    annualHa: o.annualHa || 0.5,
    perennialHa: o.perennialHa || 0.5,
    objectives: o.objectives || {balanced:"on"},
    // Perennials enriched with phenology
    perennials: (o.planSnapshot||[]).map(p => {
      const ph = getPhen(p.name);
      return {...p, ffy:ph.ffy, ytp:ph.ytp, n:ph.n, wm:p.w_max||4};
    }),
    livestock: o.lsSnapshot || [],
    annualCrops: o.annualCrops || [],
  };
  fd.tgt = calcTotals(fd.household);
  buildYearCache();
  document.getElementById("ls").style.display="none";
  document.getElementById("mn").style.display="block";
  cy=1; render();
}

// ── Year computation ──────────────────────────────────────────────────────────
function buildYearCache(){
  yc=[];
  for(let yr=1;yr<=HZ;yr++){
    const ch = Math.min(totCHa(yr), fd.perennialHa);
    const perenGap = Math.max(0, fd.perennialHa - ch);
    const availHa = fd.annualHa + perenGap;

    // Perennial contributions per food group (serves/day)
    const pn={veg:0,fruit:0,starchy:0,protein:0,dairy:0,oils:0};
    const perenDetail = fd.perennials.map(c=>{
      const spd = perenSpd(c,yr);
      const k = fgToKey(c.food_group)||'veg';
      pn[k]=(pn[k]||0)+spd;
      return {name:c.name, spd, k, pct:Math.round(Math.min(100,(yr/((c.ytp||6)*1.5))*100)),
              yt:perenYldTha(c,yr), ffy:c.ffy, ytp:c.ytp, allocHa:c.allocHa, food_group:c.food_group};
    });

    // Livestock contributions (static)
    const ln={veg:0,fruit:0,starchy:0,protein:0,dairy:0,oils:0};
    fd.livestock.forEach(ls=>{
      const spd=ls.yield_per_animal_kg_yr*ls.count*1000/(ls.adg_serve_g||150)/365;
      const k=fgToKey(ls.food_group)||'protein';
      ln[k]=(ln[k]||0)+spd;
    });

    // Residual targets for annual algorithm
    const residual={};
    Object.keys(fd.tgt).forEach(k=>{
      residual[k]=Math.max(0, fd.tgt[k]-(pn[k]||0)-(ln[k]||0));
    });

    // Run annual plan
    const plan = generateAnnualPlan(fd.annualCrops, residual, availHa, {
      hoursPerWeek: fd.hoursPerWeek,
      labourSystem: fd.labourSystem,
      fertility: fd.fertility,
      confidence: fd.confidence,
      objectives: fd.objectives,
      pastureHa: 0,
    });

    // Compute total coverage
    const annualNut={veg:0,fruit:0,starchy:0,protein:0,dairy:0,oils:0};
    (plan.achieved||{}) && Object.keys(annualNut).forEach(k=>{
      annualNut[k]=(plan.achieved||{})[k]||0;
    });

    const cov={};
    Object.keys(fd.tgt).forEach(k=>{
      const total = (pn[k]||0)+(ln[k]||0)+(annualNut[k]||0);
      cov[k] = fd.tgt[k]>0 ? Math.min(150,Math.round(total/fd.tgt[k]*100)) : 100;
    });
    const avg = Math.round(Object.values(cov).reduce((s,v)=>s+v,0)/Object.keys(cov).length);

    // Perennial coverage fraction (without annuals)
    const perenOnlyCov={};
    Object.keys(fd.tgt).forEach(k=>{
      perenOnlyCov[k]=fd.tgt[k]>0?Math.min(100,Math.round(((pn[k]||0)+(ln[k]||0))/fd.tgt[k]*100)):100;
    });

    const totL = (plan.usedLabour||0) + fd.livestock.reduce((s,ls)=>s+ls.count*(ls.labour_hrs_per_animal||8),0);
    const budL = (fd.hoursPerWeek||20)*52;

    yc.push({yr,ch,perenGap,availHa,pn,ln,annualNut,perenDetail,cov,perenOnlyCov,avg,
             plan,residual,totL,budL,labPct:Math.round(totL/budL*100)});
  }
}

